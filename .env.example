# Base URL of the SunoBro admin backend API.
# - Leave unset (defaults to same-origin "/api") if the backend is deployed
#   behind this app or proxied via next.config rewrites.
# - Set to a separate origin (e.g. https://api.sunobro.com) if the backend
#   runs as its own service. Every request path in src/lib/api/endpoints.ts
#   is appended to this base as-is — keep the backend's routes matching.
NEXT_PUBLIC_API_BASE_URL=/api

# Name of the cookie the backend sets on successful admin login. The
# middleware (src/middleware.ts) checks for this cookie to gate /admin.
ADMIN_SESSION_COOKIE=sb_admin_session

# Public URL this admin app is deployed at — used to resolve absolute
# Open Graph / Twitter share-image URLs. Set to the real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
